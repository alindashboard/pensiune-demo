# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Găsești aceste valori în Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# URL-ul proiectului tău Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Anon key (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (PRIVAT — nu expune niciodată în client)
# Folosit doar în Server Actions și funcții server-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# Resend (email)
# Creează cont la resend.com, obți API key din Settings → API Keys
# ─────────────────────────────────────────────────────────────────────────────

# API key Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresa de email la care primești notificările (admin-ul tău)
ADMIN_EMAIL=admin@example.com
